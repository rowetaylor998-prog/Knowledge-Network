# AI can be disabled, proxied to your existing AI web app, or connected directly to OpenAI.
ENABLE_AI=true
AI_PROVIDER=external

# Direct OpenAI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# External AI provider: proxy to an already-deployed AI web app.
EXTERNAL_AI_BASE_URL=
EXTERNAL_AI_CHAT_ENDPOINT=/chat-web
EXTERNAL_AI_TIMEOUT_SECONDS=45

# MVP budget controls
AI_DAILY_LIMIT=20
AI_CACHE_ENABLED=true
